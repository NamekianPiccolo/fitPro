{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FitAI Pro",
  "version": "1.0.0",
  "identifier": "com.fitai.pro",
  "build": {
    "frontendDist": "../dist",
    "beforeBuildCommand": "python build_dist.py"
  },
  "app": {
    "windows": [
      {
        "title": "FitAI Pro - AI Exercise Tracker",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
